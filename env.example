# --- Core ---------------------------------------------------------------------
DATABASE_URL="postgresql://zenith:zenith_dev_password@localhost:5432/zenithire?schema=public"
APP_URL="https://app.zenithire.com"
PORT=3000
CORS_ORIGIN="https://app.zenithire.com"
NODE_ENV="development"

# --- Auth -----------------------------------------------------------------------
JWT_ACCESS_SECRET="replace-with-a-long-random-value"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="replace-with-a-different-long-random-value"
JWT_REFRESH_EXPIRES_IN="7d"

# --- Redis (BullMQ job queue for video processing) --------------------------------
REDIS_HOST="localhost"
REDIS_PORT=6379

# --- Storage (S3-compatible) ------------------------------------------------------
AWS_REGION="eu-west-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET="zenithire-media"
CDN_BASE_URL="https://media.zenithire.com"

# --- Payments ---------------------------------------------------------------------
PAYSTACK_SECRET_KEY=""
FLUTTERWAVE_SECRET_KEY=""
FLUTTERWAVE_WEBHOOK_HASH=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_CANDIDATE_PREMIUM=""
STRIPE_PRICE_EMPLOYER_PREMIUM=""
